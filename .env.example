# =============================================================================
# AGENT TEMPLATE — GENERAL
# =============================================================================
# HTTP_PORT also reads Cloud Run PORT. USE_API_PREFIX=false → no /api/{env}/{name} prefix.
HTTP_PORT=8005
USE_API_PREFIX=true
API_ENVIRONMENT=dev
API_AGENT_NAME=dooers-starter
SERVICE_URL=http://localhost:8005
# Optional display fallback (see src/config.py — ASSISTANT_NAME)
ASSISTANT_NAME=Assistant
# Root log level for this process (DEBUG, INFO, …). Azure SDK / httpx stay at WARNING by default — see configure_logging() in src/main.py.
LOGGING_LEVEL=INFO

# =============================================================================
# DATABASE (agent threads / events / settings)
# =============================================================================
AGENT_DATABASE_HOST=localhost
AGENT_DATABASE_PORT=5432
AGENT_DATABASE_USER=postgres
AGENT_DATABASE_PASSWORD=postgres
AGENT_DATABASE_NAME=dooers_agent
AGENT_DATABASE_SSL=false

# =============================================================================
# STORAGE & UPLOADS (chat + shared GCS/Azure credentials)
# =============================================================================
# Chat ContentPart allowlist for SDK event.create (see AgentConfig.allowed_content_types).
AGENT_ALLOWED_CONTENT_TYPES=text,audio,image
# Ops: durable chat blobs when creator enables persist_chat_attachments + POST /uploads with agent_id.
STORE_CHAT_UPLOADS=false
# Chat blob backend for SDK: none | gcp | azure
CHAT_STORAGE_SERVICE=none

# GCS — bucket name; auth via GOOGLE_APPLICATION_CREDENTIALS or workload identity (ADC)
GCP_BUCKET_NAME=
# GCS — path to YOUR service account JSON locally (never commit this file)
GOOGLE_APPLICATION_CREDENTIALS=

# Azure Blob — same credentials used for chat blobs (SDK) and RAG archive (template) when you pick azure
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=

# Optional — SDK signed read URLs for chat artifacts (see dooers.config.AgentConfig)
# CHAT_ARTIFACT_SIGNED_URL_TTL_MINUTES=60

# =============================================================================
# RAG — vector pipeline & archive of upload originals
# =============================================================================
# Vector index: openai (OpenAI vector store) | azure_ai_search
RAG_PIPELINE=openai
# Ops: write RAG **original file** copies to blob (upload_archive_bytes). Needs RAG_STORAGE_SERVICE=gcp|azure.
# Blob key layout: rag-artifacts/v1/{agent_id}/{field_id}/{artifact_ref}/{filename}
STORE_RAG_UPLOADS=false
# Blob destination for RAG originals: none | gcp | azure
RAG_STORAGE_SERVICE=none

# =============================================================================
# RAG — Azure AI Search (when using RAG_PIPELINE=azure_ai_search or env fallback)
# =============================================================================
AZURE_AI_SEARCH_ENDPOINT=https://YOUR_SEARCH_RESOURCE.search.windows.net
AZURE_AI_SEARCH_API_KEY=
AZURE_AI_SEARCH_INDEX_PREFIX=dooers-kb
AZURE_AI_SEARCH_VERIFY_READ_AFTER_WRITE=0

# =============================================================================
# LLM — OpenAI API (RAG_PIPELINE=openai; also exported for Agents SDK traces)
# =============================================================================
OPENAI_API_KEY=

# =============================================================================
# DOOERS PLATFORM
# =============================================================================
DOOERS_ANALYTICS_WEBHOOK_URL=http://localhost:4000/api/v2/webhooks/analytics
AGENT_SEED_SECRET=

# WhatsApp tools base URL (can include path prefix).
# Default in code is https://services.dooers.ai/whatsapp
# DOOERS_WHATSAPP_TOOLS_BASE=https://services.dooers.ai/whatsapp
# If USE_API_PREFIX=true, Studio inbound URL = {SERVICE_URL}/api/{API_ENVIRONMENT}/{API_AGENT_NAME}/whatsapp/inbound

# -----------------------------------------------------------------------------
# Chat / LLM via Azure OpenAI, STT/TTS — configure in agent settings UI, not here.
# -----------------------------------------------------------------------------
